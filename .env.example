APP_NAME="Dashboard"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost
AUTH_MODEL=Uneca\Chimera\Models\User

APP_PORT=80
FORWARD_DB_PORT=5432
FORWARD_DATASOURCE_PORT=3306

APP_OWNER_NAME=ECA
APP_OWNER_URL=#
CACHE_TTL_SECONDS=1800
MAIL_ENABLED=false
ENFORCE_2FA=false
INDICATORS_PER_PAGE=2
INVITATION_TTL_HOURS=72
MAP_CENTER_LAT=0.0236
MAP_CENTER_LON=37.9062
MAP_STARTING_ZOOM=6
MAP_MIN_ZOOM=6
REQUIRE_ACCOUNT_APPROVAL=false
RECORDS_PER_PAGE=20
SECURE=false
LONG_QUERY_TIME=10
FEATURED_INDICATORS_PER_DATA_SOURCE=2
SHAPEFILE_IMPORT_CHUNK_SIZE=500
SHAPEFILE_STOP_IMPORT_IF_ORPHANS_FOUND=true
PROGRESS_UPDATE_INTERVAL_SECONDS=25
COLOR_THEME=Chimera
MAP_MENU=on
REPORTS_MENU=on

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=dashboard
DB_USERNAME=sail
DB_PASSWORD=password

DATASOURCE_HOST=mysql
DATASOURCE_PORT=3306
DATASOURCE_DATABASE=kenya_census
DATASOURCE_USERNAME=sail
DATASOURCE_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=background

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
